rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if true;
    }

    // Game Room Rules
    match /rooms/{roomId} {
      allow read, write: if true;

      // Player Subcollection Rules (Nested)
      match /players/{playerId} {
        allow read, write: if true;
      }

      // Log/Chat Subcollection Rules (Nested)
      match /logs/{logId} {
        allow read, write: if true;
      }
    }
  }
}
